{
  "name": "@stellar-raise/contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "PATH=\"$HOME/.cargo/bin:$PATH\" cargo build --manifest-path ../../Cargo.toml --target wasm32-unknown-unknown --release",
    "test": "PATH=\"$HOME/.cargo/bin:$PATH\" cargo build --manifest-path ../../Cargo.toml --target wasm32-unknown-unknown --release && PATH=\"$HOME/.cargo/bin:$PATH\" cargo test --manifest-path ../../Cargo.toml --workspace",
    "lint": "PATH=\"$HOME/.cargo/bin:$PATH\" cargo clippy --manifest-path ../../Cargo.toml --workspace -- -D warnings || true",
    "lint:fix": "PATH=\"$HOME/.cargo/bin:$PATH\" cargo clippy --manifest-path ../../Cargo.toml --workspace --fix --allow-dirty -- -D warnings || true",
    "format": "PATH=\"$HOME/.cargo/bin:$PATH\" cargo fmt --manifest-path ../../Cargo.toml --all || true",
    "format:check": "PATH=\"$HOME/.cargo/bin:$PATH\" cargo fmt --manifest-path ../../Cargo.toml --all -- --check || true",
    "dev": "echo 'No dev server for contracts. Use pnpm build to compile.'"
  }
}
